### This .env file is for running utility scripts in the main package.json
### A separate .env file under packages/application is used for the main docs app

## If a rebuild of Contentful-based docs is required
CONTENTFUL_FORCE_BUILD=true

## Contentful content delivery token
CONTENTFUL_TOKEN=CFPAT--o5njvgpT_wV44mbFDuqU9PsQyhhm37fShDw60-0fxA

## For running validations (yarn validate:all)
PORT=3000


# Api Docs
API2_SCHEMA_DOMAIN=login0.local.dev.auth0.com
TARGET_API2_SCHEMA_DOMAIN=login.auth0.com
API2_SCHEMA_DOCS_URL=https://manage.local.dev.auth0.com/docs
TARGET_API2_SCHEMA_DOCS_URL=https://auth0.com/docs

# Target API2 branch used in schema generation
API2_SCHEMA_TARGET_BRANCH=oas3-schema-updates
API2_SCHEMA_TARGET_COMMIT=c9f9469ba89ad50d52311cc008acd89dd8e06a95
